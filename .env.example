# =============================================================================
# Ace It / Tide-AI 环境变量示例
# =============================================================================
# 复制本文件为 .env 并填写真实值。.env 已在 .gitignore 中，不会被提交。
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库（PostgreSQL）
# -----------------------------------------------------------------------------
# 本地开发：Docker 容器 tide-ai-postgres，映射 5433 -> 5432
# 用户/库/密码 = tideai/password123/tideai
DATABASE_URL="postgresql://tideai:password123@localhost:5433/tideai"

# -----------------------------------------------------------------------------
# 认证 - NextAuth.js v4 + JWT
# -----------------------------------------------------------------------------
# 用于签名 NextAuth session 和 JWT token，使用 `openssl rand -base64 32` 生成
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32-output"
# JWT 自定义签名密钥（server/auth/jwt.ts 使用 jose 库），缺失时启动直接报错
JWT_SECRET="replace-with-openssl-rand-base64-32-output"
# 本地开发地址，生产部署时改为实际域名
NEXTAUTH_URL="http://localhost:3000"

# OAuth 提供商（可选，不填则只支持邮箱密码登录）
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub Developer Settings: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# AI 服务 - SiliconFlow
# -----------------------------------------------------------------------------
# 申请地址：https://cloud.siliconflow.cn
# 用户可在个人设置页配置自己的 key，此处为系统兜底默认 key
SILICONFLOW_API_KEY="sk-your-siliconflow-api-key-here"
# 可选：兼容 OpenAI 接口的其他服务（如自建中转）
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# 运行时配置（可选）
# -----------------------------------------------------------------------------
# 临时关闭认证守卫（仅 dev），设为 "true" 或 "1" 时 AuthGuard 直接放行
NEXT_PUBLIC_DISABLE_AUTH=""
# 生产构建使用 standalone 输出（Docker 部署用）
NEXT_STANDALONE=""
# 构建产物体积分析（ANALYZE=true pnpm build 后会打开浏览器报告）
ANALYZE=""
